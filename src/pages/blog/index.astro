---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BlogLayout from "../../components/BlogLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const siteUrl = "https://kaosi-anikwe.pages.dev";
const title = "Writing — Kaosi Anikwe";
const description =
  "Reflections on backend engineering, systems design, and lessons learned building under real constraints.";
---

<BlogLayout
  title={title}
  description={description}
  canonicalUrl={`${siteUrl}/blog`}
>
  <style slot="head">
    html, body { height: 100%; margin: 0; }
    body { background: #000; color: #fff; font-family: 'Geist', 'Inter', ui-sans-serif, system-ui, sans-serif; }
  </style>

  <div class="relative min-h-screen w-full">
    <!-- Ambient gradient -->
    <div
      aria-hidden
      class="pointer-events-none fixed inset-x-0 top-0 h-[50vh] z-0"
      style="background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(120,20,55,0.3) 0%, rgba(0,0,0,0) 100%);"
    ></div>

    <div class="relative z-10 mx-auto w-full max-w-160 px-8">
      <!-- NAV -->
      <nav class="pt-10 pb-4 flex items-center justify-between">
        <a
          href="/"
          class="opacity-40 hover:opacity-100 transition-opacity text-[10px] uppercase"
          style="letter-spacing: 1px; font-family: 'JetBrains Mono', monospace;"
        >
          ← Back
        </a>
        <span
          class="text-[10px] uppercase opacity-30"
          style="letter-spacing: 1px; font-family: 'JetBrains Mono', monospace;"
        >
          Writing
        </span>
      </nav>

      <!-- HEADER -->
      <section class="pt-16 pb-12">
        <h1
          class="text-[40px] leading-tight"
          style="font-weight: 500; letter-spacing: -1.5px; font-family: 'Monsieur La Doulaise', cursive;"
        >
          Writing
        </h1>
        <p
          class="opacity-50 mt-3 text-[14px] leading-[22.75px]"
          style="font-weight: 300;"
        >
          Reflections on backend engineering, systems design, and lessons
          learned along the way.
        </p>
      </section>

      <!-- POST LIST -->
      <section class="pb-20">
        <div class="flex flex-col gap-0">
          {posts.map((post: CollectionEntry<"blog">) => (
            <a
              href={`/blog/${post.id.replace(/\.mdx?$/, "")}`}
              class="group block py-8 border-t border-white/10 hover:border-white/20 transition-colors"
            >
              <div class="flex items-start justify-between gap-8">
                <div class="flex-1 min-w-0">
                  <p
                    class="text-[10px] uppercase opacity-30 mb-3"
                    style="letter-spacing: 1px; font-family: 'JetBrains Mono', monospace;"
                  >
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </p>
                  <h2
                    class="text-[20px] leading-7 group-hover:opacity-80 transition-opacity"
                    style="font-weight: 500; letter-spacing: -0.4px;"
                  >
                    {post.data.title}
                  </h2>
                  <p
                    class="opacity-50 text-[14px] leading-[22.75px] mt-2"
                    style="font-weight: 300;"
                  >
                    {post.data.description}
                  </p>
                  <div class="flex flex-wrap gap-2 mt-4">
                    {post.data.tags.map((tag: string) => (
                      <span
                        class="text-[10px] uppercase px-2 py-0.5 rounded border border-white/10 text-white/50"
                        style="letter-spacing: 0.5px; font-family: 'JetBrains Mono', monospace;"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
                <span
                  class="opacity-20 group-hover:opacity-60 transition-opacity text-[20px] mt-1 flex-shrink-0"
                  aria-hidden="true"
                >
                  →
                </span>
              </div>
            </a>
          ))}
          {posts.length === 0 && (
            <p class="opacity-40 text-[14px] pt-8" style="font-weight: 300;">
              No posts yet.
            </p>
          )}
        </div>
      </section>

      <!-- FOOTER -->
      <footer class="border-t border-white/10 pt-10 pb-10 flex items-center justify-between">
        <p
          class="text-[10px] uppercase leading-3.75 opacity-30"
          style="font-weight: 500; letter-spacing: 1px;"
        >
          © 2026 Kaosi Anikwe.<br />
          All Rights Reserved.
        </p>
        <a
          href="/"
          class="opacity-30 hover:opacity-80 transition-opacity text-[10px] uppercase"
          style="letter-spacing: 1px;"
        >
          Portfolio →
        </a>
      </footer>
    </div>
  </div>
</BlogLayout>
